@page
@model PackageDeliverySystem.Pages.CustomerViews.PackageSendPages.PackageSendModel
@{
}
<form method="post">
	<div class="border p-3 mt-4">
		<div class="row pb-2">
			<h2 class="text-primary pl-3">Send New Package</h2>
		</div>

		<div asp-validation-summary="ModelOnly" class="text-danger"></div>

		<div class="mb-3">
			<label asp-for="@Model.Package.CustomerId"></label>
			<select asp-for="@Model.Package.CustomerId" class="form-select" asp-items="@Model.Customers">
				<option disabled selected value=""> --Select Customer--- </option>
			</select>
			<span asp-validation-for="@Model.Package.CustomerId" class="text-danger"></span>
		</div>
		<div class="mb-3">
			<label asp-for="@Model.Package.RecipientName"></label>
			<input asp-for="@Model.Package.RecipientName" class="form-control" />
			<span asp-validation-for="@Model.Package.RecipientName" class="text-danger"></span>
		</div>
		<div class="mb-3">
			<label asp-for="@Model.Package.Destination"></label>
			<input asp-for="@Model.Package.Destination" class="form-control" />
			<span asp-validation-for="@Model.Package.Destination" class="text-danger"></span>
		</div>
		<div class="mb-3">
			<label asp-for="@Model.Package.Type"></label>
			<select asp-for="@Model.Package.Type" id="packageType" class="form-select" asp-items="@(Html.GetEnumSelectList<PackageDeliverySystem.Models.Models.Package.PackageType>())">
				<option disabled selected> --Select Package Type--- </option>
			</select>
			<span asp-validation-for="@Model.Package.Type" class="text-danger"></span>
		</div>
		<div class="mb-3">
			<label asp-for="@Model.Package.Weight"></label>
			<input asp-for="@Model.Package.Weight" id="packageWeight" type="number" step="0.1" min="0.1" class="form-control" />
			<span asp-validation-for="@Model.Package.Weight" class="text-danger"></span>
		</div>
		<div class="mb-3">
			<label asp-for="@Model.Package.DeliveryDate"></label>
			<input asp-for="@Model.Package.DeliveryDate" type="date" min="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")" class="form-control" />
			<span asp-validation-for="@Model.Package.DeliveryDate" class="text-danger"></span>
		</div>

		<button type="submit" class="btn btn-primary">Send Package</button>
		<a asp-page="Index" class="btn btn-secondary">Back to Index</a>
	</div>
</form>

@section Scripts {
	@{
		<partial name="_validationScriptsPartial" />
	}
	<script>
		document.addEventListener("DOMContentLoaded", function () {
			var typeSelect = document.getElementById("packageType");
			var weightInput = document.getElementById("packageWeight");

			function toggleWeight() {
				// "0" matches the int value of PackageType.Letter
				if (typeSelect.value === "0") {
					weightInput.disabled = true;
					weightInput.value = "1";
				} else {
					weightInput.disabled = false;
				}
			}

			typeSelect.addEventListener("change", toggleWeight);
			toggleWeight();
		});
	</script>
}