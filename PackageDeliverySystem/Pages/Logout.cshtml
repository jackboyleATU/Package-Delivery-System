@page
@model PackageDeliverySystem.Pages.LogoutModel
@{
}
<div class="container d-flex justify-content-center align-items-center" style="min-height:70vh;">

    <form method="post" class="w-100" style="max-width:420px;">

        <div class="bg-dark text-white rounded-3 shadow p-4 text-center d-flex flex-column">

            <div asp-validation-summary="All" class="text-danger mb-2"></div>

            <!-- Icon -->
            <div class="mb-3">
                <img src="~/images/homePage/magnifyingGlass.png"
                     alt="Logout"
                     style="height:70px;">
            </div>

            <!-- Title -->
            <h4 class="fw-bold text-uppercase mb-2">Logout</h4>

            <!-- Message -->
            <p class="text-light small mb-4">
                Are you sure you want to log out of your account?
            </p>

            <!-- Buttons -->
            <div class="d-grid gap-2 mt-auto">
                <button class="btn btn-danger fw-semibold" asp-page-handler="Logout">
                    Yes, Log Out →
                </button>

                <button class="btn btn-outline-light" asp-page-handler="NoLogout">
                    Cancel
                </button>
            </div>

        </div>

    </form>
</div>