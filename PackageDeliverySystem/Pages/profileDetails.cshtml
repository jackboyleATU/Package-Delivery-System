@page
@using Microsoft.AspNetCore.Identity
@using PackageDeliverySystem.Models.Models
@using PackageDeliverySystem.Services
@inject SignInManager<ApplicationUser> signInManager
@inject UserManager<ApplicationUser> userManager
@inject IUnitOfWork unitOfWork
@model PackageDeliverySystem.Pages.profileDetailsModel

<div class="container">
    <div class="main-body">
          <div class="row gutters-sm">
            <div class="col-md-4 mb-3">
              <div class="card">
                <div class="card-body">
                  <div class="d-flex flex-column align-items-center text-center">
                    <img src="~/images/defaultProfile.png" alt="Admin" class="rounded-circle" width="150">
                    <div class="mt-3">
                      <h4>
                        @if(Model.customer != null) { @Model.customer.Name }
                        @if(Model.employee != null) { @Model.employee.Name }
                      </h4>
                      <p class="text-muted font-size-sm">
                        @if(Model.customer != null) { @Model.customer.Address }
                        @if(Model.employee != null) { @Model.employee.Address }
                      </p>
                    </div>
                  </div>
                </div>
              </div>
              <div class="card mt-3">
                <ul class="list-group list-group-flush">
                @if(User.IsInRole("Customer") && Model.customer != null)
                {
                  <li class="list-group-item d-flex justify-content-between align-items-center flex-wrap">
                    <h6 class="mb-0"><a href="CustomerViews/PackageTracking/AccountTrack">Packages</a></h6>
                    <span class="text-secondary">@(Model.customer.Packages?.Count ?? 0)</span>
                  </li>        
                }
                @if(User.IsInRole("Driver") && Model.employee != null)
                {
                  <li class="list-group-item d-flex justify-content-between align-items-center flex-wrap">
                    <h6 class="mb-0"><a asp-page="Driver/Index">Packages to be delivered</a></h6>
                                <span class="text-secondary">@(Model.packagesToBeDelivered?.Count())</span>
                           </li>        
                }
                @if(User.IsInRole("Admin") && Model.employee != null)
                {
                  <li class="list-group-item d-flex justify-content-between align-items-center flex-wrap">
                    <h6 class="mb-0"><a asp-page="Admin/Employee/Index">Employee Count</a></h6>
                                <span class="text-secondary">@(Model.employeeCount?.Count())</span>
                           </li>  
                  <li class="list-group-item d-flex justify-content-between align-items-center flex-wrap">
                    <h6 class="mb-0"><a asp-page="Admin/Customer/Index">Customer Count</a></h6>
                                <span class="text-secondary">@(Model.customerCount?.Count())</span>
                           </li>   
                }
                </ul> 
              </div>
            </div>
            <div class="col-md-8">
              <div class="card mb-3">
                <div class="card-body">
                  <div class="row">
                    <div class="col-sm-3">
                      <h6 class="mb-0">Full Name</h6>
                    </div>
                    <div class="col-sm-9 text-secondary">
                      @Model.customer?.Name
                      @Model.employee?.Name
                    </div>
                  </div>
                  <hr>
                  <div class="row">
                    <div class="col-sm-3">
                      <h6 class="mb-0">Email</h6>
                    </div>
                    @if(@User.IsInRole("Customer") && Model.customer != null)
                    {
                    <div class="col-sm-9 text-secondary">
                      @Model.customer.Email
                    </div>
                    }
                    @if ((@User.IsInRole("Driver") || @User.IsInRole("Admin")) && Model.employee != null)
                    {
                        <div class="col-sm-9 text-secondary">
                            @(Model.employee.Username)@@gmail.com
                        </div>
                    }
                  </div>
                  <hr>
                  @if(@User.IsInRole("Customer") && Model.customer != null)
                    {
                    <div class="row">
                    <div class="col-sm-3">
                      <h6 class="mb-0">Phone Number</h6>
                    </div>
                    <div class="col-sm-9 text-secondary">
                      @Model.customer?.PhoneNumber
                    </div>
                  </div>
                  <hr>
                    }
                  @if((@User.IsInRole("Driver") || @User.IsInRole("Admin")) && Model.employee != null)
                  {
                  <div class="row">
                    <div class="col-sm-3">
                      <h6 class="mb-0">Username</h6>
                    </div>
                    <div class="col-sm-9 text-secondary">
                      @Model.employee.Username
                    </div>
                  </div>
                  <hr>
                  }
                  <div class="row">
                    <div class="col-sm-3">
                      <h6 class="mb-0">Address</h6>
                    </div>
                    <div class="col-sm-9 text-secondary">
                      @Model.customer?.Address@Model.employee?.Address
                    </div>
                  </div>

                  @if((@User.IsInRole("Driver") || @User.IsInRole("Admin")) && Model.employee != null)
                  {
                    <hr />
                    <div class="row">
                    <div class="col-sm-3">
                      <h6 class="mb-0">Department</h6>
                    </div>
                    <div class="col-sm-9 text-secondary">
                      @Model.employee.Dept
                    </div>
                  </div>
                  <hr />
                      <div class="row">
                    <div class="col-sm-3">
                      <h6 class="mb-0">Salary</h6>
                    </div>
                    <div class="col-sm-9 text-secondary">
                      €@Model.employee?.Salary
                    </div>
                  </div>
                  }
                </div>
              </div>
            </div>
          </div>

        </div>
    </div>

<style>
body{
    color: #1a202c;
    text-align: left;
    background-color: #e2e8f0;    
}
.main-body {
    padding: 15px;
}
.card {
    box-shadow: 0 1px 3px 0 rgba(0,0,0,.1), 0 1px 2px 0 rgba(0,0,0,.06);
}

.card {
    position: relative;
    display: flex;
    flex-direction: column;
    min-width: 0;
    word-wrap: break-word;
    background-color: #fff;
    background-clip: border-box;
    border: 0 solid rgba(0,0,0,.125);
    border-radius: .25rem;
}

.card-body {
    flex: 1 1 auto;
    min-height: 1px;
    padding: 1rem;
}

.gutters-sm {
    margin-right: -8px;
    margin-left: -8px;
}

.gutters-sm>.col, .gutters-sm>[class*=col-] {
    padding-right: 8px;
    padding-left: 8px;
}
.mb-3, .my-3 {
    margin-bottom: 1rem!important;
}

.bg-gray-300 {
    background-color: #e2e8f0;
}
.h-100 {
    height: 100%!important;
}
.shadow-none {
    box-shadow: none!important;
}
</style>