@page
@model PackageDeliverySystem.Pages.CustomerViews.IndexModel
@{
}
<div class="container-fluid p-0">

    <!-- Banner -->
    <div class="position-relative text-white">
        <img src="~/images/banner.jpg"
             class="img-fluid w-100"
             style="max-height:300px; object-fit:cover;"
             alt="Banner">

        <!-- Optional overlay -->
        <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark opacity-50"></div>

        <!-- Banner text -->
        <div class="position-absolute top-50 start-50 translate-middle text-center">
            <h2 class="fw-bold mb-2">Fast & Reliable Delivery</h2>
            <p class="mb-0">Send and track your packages </p>
        </div>
    </div>

    <!-- Cards -->
    <div class="container py-4">
        <div class="row g-4 justify-content-center">

            <!-- Send Package -->
            <div class="col-md-6 col-lg-4">
                <div class="bg-body-secondary text-dark rounded-3 shadow h-100 d-flex flex-column text-center p-4">

                    <div class="mb-3">
                        <img src="~/images/homePage/parcel.png"
                             alt="Send Package"
                             style="height:90px;">
                    </div>

                    <h4 class="fw-bold text-uppercase mb-2">Send Package</h4>
                    <p class="small mb-4">
                        Create and send deliveries quickly and easily.
                    </p>

                    <div class="mt-auto">
                        <a href="CustomerViews/PackageSendPages/PackageSend"
                           class="btn btn-dark w-100 py-2 fw-semibold">
                            Start Shipping →
                        </a>
                    </div>

                </div>
            </div>

            <!-- Track Package -->
            <div class="col-md-6 col-lg-4">
                <div class="bg-dark text-white rounded-3 shadow h-100 d-flex flex-column text-center p-4">

                    <div class="mb-3">
                        <img src="~/images/homePage/magnifyingGlass.png"
                             alt="Track Package"
                             style="height:90px;">
                    </div>

                    <h4 class="fw-bold text-uppercase mb-2">Track Package</h4>
                    <p class="small mb-4">
                        Get real-time updates on your shipment.
                    </p>

                    <div class="mt-auto">
                        <a href="CustomerViews/PackageTracking/PackageTrack"
                           class="btn btn-light w-100 py-2 fw-semibold">
                            Track Now →
                        </a>
                    </div>

                </div>
            </div>

        </div>
    </div>

</div>