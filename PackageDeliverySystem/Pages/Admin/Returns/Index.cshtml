@page
@model PackageDeliverySystem.Pages.Admin.Returns.IndexModel
@{
}

<div action="container p-3">
    <div class="row pt-4">
        <div class="col-12">
            <h3 class="text-primary">Returns (3+ Attempted Deliveries)</h3>
        </div>
    </div>
</div>

<br />

@if (!string.IsNullOrWhiteSpace(Model.FlashMessage))
{
    <div class="alert alert-info">@Model.FlashMessage</div>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Customer (Sender)</th>
            <th>Recipient</th>
            <th>Destination</th>
            <th>Status</th>
            <th>Attempts</th>
            <th style="width:160px;"></th>
            <th style="width:120px;"></th>
        </tr>
    </thead>
    <tbody>
        @if (Model.ReturnPackages == null || !Model.ReturnPackages.Any())
        {
            <tr>
                <td colspan="7">No packages currently eligible for return.</td>
            </tr>
        }
        else
        {
            foreach (var p in Model.ReturnPackages)
            {
                <tr>
                    <td>@p.Customer?.Name</td>
                    <td>@p.RecipientName</td>
                    <td>@p.Destination</td>
                    <td>@p.Status</td>
                    <td>@p.AttemptedDeliveries</td>

                    <td>
                        <form method="post" asp-page-handler="ReturnToSender">
                            <input type="hidden" name="id" value="@p.Id" />
                            <button type="submit" class="btn btn-warning btn-sm">
                                Return to sender
                            </button>
                        </form>
                    </td>

                    <td>
                        <form method="post" asp-page-handler="Delete" onsubmit="return confirm('Delete this package from the system?');">
                            <input type="hidden" name="id" value="@p.Id" />
                            <button type="submit" class="btn btn-danger btn-sm">
                                Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>