@page
@model PackageDeliverySystem.Pages.Admin.Customers.EditModel
@{
}
<form method="post">
	<input hidden asp-for="Customer.Id" />
	<div class="border p-3 mt-4">
		<div class="row pb-2">
			<h2 action="text-primary pl-3">Update Category</h2>
		</div>

		<div class="mb-3">
			<label asp-for="Customer.Name"></label>
			<input asp-for="Customer.Name" class="form-control" />
			<span asp-validation-for="Customer.Name" class="text-danger"></span>
		</div>
		<div class="mb-3">
			<label asp-for="Customer.PhoneNumber"></label>
			<input asp-for="Customer.PhoneNumber" class="form-control" />
			<span asp-validation-for="Customer.PhoneNumber" class="text-danger"></span>
		</div>
		<div>
			<label asp-for="Customer.Address"></label>
			<input asp-for="Customer.Address" class="form-control" />
			<span asp-validation-for="Customer.Address" class="text-danger"></span>
		</div>
		<div class="mb-3">
			<label asp-for="Customer.Email"></label>
			<input asp-for="Customer.Email" class="form-control" />
			<span asp-validation-for="Customer.Email" class="text-danger"></span>
		</div>

		<button type="submit" class="btn btn-primary">Update</button>
		<a asp-page="Index" class="btn btn-secondary">Back to Index</a>
	</div>
</form>
