@page
@model PackageDeliverySystem.Pages.RegisterModel
@{
}
<section class="vh-60" style="background-color: #eee;">
	<div class="container h-60">
		<div class="row d-flex justify-content-center align-items-center h-60">
			<div class="col-lg-12 col-xl-11">
				<div class="card text-black" style="border-radius: 25px;">
					<div class="card-body p-md-5">
						<div class="row justify-content-center">
							<div class="col-md-10 col-lg-6 col-xl-5 order-2 order-lg-1">

								<form method="post">
									<div class="border p-3 mt-4">
										<div asp-validation-summary="All" class="text-danger"></div>
										<div class="row pb-2">
											<h2 class="text-primary pl-3">
												Register
											</h2>
										</div>
										<div class="mb-3">
											<label asp-for="Register.FirstName"></label>
											<input asp-for="Register.FirstName" class="form-control" />
											<span asp-validation-for="Register.FirstName" class="text-danger"></span>
										</div>
										<div class="mb-3">
											<label asp-for="Register.LastName"></label>
											<input asp-for="Register.LastName" class="form-control" />
											<span asp-validation-for="Register.LastName" class="text-danger"></span>
										</div>
										<div class="mb-3">
											<label asp-for="Register.PhoneNumber"></label>
											<input asp-for="Register.PhoneNumber" class="form-control" />
											<span asp-validation-for="Register.PhoneNumber" class="text-danger"></span>
										</div>
										<div>
											<label asp-for="Register.Address"></label>
											<input asp-for="Register.Address" class="form-control" />
											<span asp-validation-for="Register.Address" class="text-danger"></span>
										</div>
										<div class="mb-3">
											<label asp-for="Register.EmailAddress"></label>
											<input asp-for="Register.EmailAddress" class="form-control" />
											<span asp-validation-for="Register.EmailAddress" class="text-danger"></span>
										</div>
										<div class="mb-3">
											<label asp-for="Register.Password"></label>
											<input asp-for="Register.Password" class="form-control" />
											<span asp-validation-for="Register.Password" class="text-danger"></span>
										</div>
										<div class="mb-3">
											<label asp-for="Register.ConfirmPassword"></label>
											<input asp-for="Register.ConfirmPassword" class="form-control" />
											<span asp-validation-for="Register.ConfirmPassword" class="text-danger"></span>
										</div>



										<button type="submit" class="btn btn-primary">Register</button>
									</div>
								</form>

							</div>
							<div class="col-md-10 col-lg-6 col-xl-7 d-flex align-items-center order-1 order-lg-2">

								<img src="/images/logo.png"
									 class="img-fluid" alt="Sample image">

							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
</section>

@section Scripts {
	@{
		<partial name="_validationScriptsPartial" />
	}
}
