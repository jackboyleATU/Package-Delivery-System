@using Microsoft.AspNetCore.Identity
@using PackageDeliverySystem.Models.Models
@using PackageDeliverySystem.Services
@inject SignInManager<ApplicationUser> signInManager
@inject UserManager<ApplicationUser> userManager
@inject IUnitOfWork unitOfWork

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PackageDeliverySystem</title>

    <link rel="stylesheet" href="~/css/bootstrapFlatly.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg bg-dark" data-bs-theme="dark">
            <div class="container-fluid">
                <a class="navbar-brand" href="#">
                    <img src="~/images/logo.png" height="40" />
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarColor01" aria-controls="navbarColor01" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarColor01">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-page="/Index">Home</a>
                        </li>
                    </ul>

                    @if (signInManager.IsSignedIn(User))
                    {
                        @if (User.IsInRole("Driver"))
                        {
                            <ul class="navbar-nav">
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button">Driver</a>
                                    <div class="dropdown-menu">
                                        <a class="dropdown-item" href="/Driver/Index">Index</a>
                                        <a class="dropdown-item" href="/Driver/DeliveryList">Delivery List</a>
                                    </div>
                                </li>
                            </ul>
                        }

                        @if (User.IsInRole("Driver"))
                        {
                            <ul class="navbar-nav">
                                <li class="nav-item">
                                    <a class="nav-link" href="/Driver/Index">Begin Deliveries</a>
                                </li>
                            </ul>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <ul class="navbar-nav">
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button">Administration</a>
                                    <div class="dropdown-menu">
                                        <a class="dropdown-item" href="/Admin/Customers/Index">Customers</a>
                                        <a class="dropdown-item" href="/Admin/Employees/Index">Employees</a>
                                        <a class="dropdown-item" href="/Admin/Packages/Index">Packages</a>
                                        <div class="dropdown-divider"></div>
                                        <a class="dropdown-item" href="/Admin/Returns/Index">Returns</a>
                                    </div>
                                </li>
                            </ul>
                        }

                        @if (signInManager.IsSignedIn(User))
                        {


                            @if (User.IsInRole("Customer"))
                            {
                                var currentUser = await userManager.GetUserAsync(User);
                                var unreadCount = 0;

                                if (currentUser?.CustomerId != null)
                                {
                                    unreadCount = unitOfWork.CustomerEmailRepo.GetUnreadCount(currentUser.CustomerId.Value);
                                }

                                if (unreadCount > 0)
                                {
                                    <ul class="navbar-nav ms-2 justify-content-end">
                                        <li class="nav-item d-flex align-items-center">
                                            <a class="btn btn-warning position-relative fw-bold px-3" asp-page="/CustomerViews/Notifications/Index">
                                                🔔 Notifications
                                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                                    @unreadCount
                                                    <span class="visually-hidden">unread notifications</span>
                                                </span>
                                            </a>
                                        </li>
                                    </ul>
                                }
                            }
                        }

                        <ul class="navbar-nav flex-grow-1 justify-content-end">
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button">Profile</a>
                                <div class="dropdown-menu dropdown-menu-end">
                                    <a class="dropdown-item" asp-area="" asp-page="/profileDetails">Details</a>
                                    <div class="dropdown-divider"></div>
                                    <a class="dropdown-item" asp-area="" asp-page="/Logout">Logout</a>
                                </div>
                            </li>
                        </ul>
                    }
                    else
                    {
                        <ul class="navbar-nav flex-grow-1 justify-content-end">
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-area="" asp-page="/Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-area="" asp-page="/Register">Register</a>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - PackageDeliverySystem - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>